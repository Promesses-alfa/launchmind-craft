{#
  Launchmind blog — article list.

  This is a self-contained starter template. To restyle it, copy this file to
  templates/launchmind-blog/blog/index.twig in your own project and edit freely,
  or ignore the bundled routes entirely and pull data with craft.launchmind.posts().

  Available: posts (array), page (int), hasNextPage (bool), blogPath (string)
#}
<!DOCTYPE html>
<html lang="{{ craft.app.language }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ 'Blog'|t('launchmind-blog') }}{% if siteName ?? null %} — {{ siteName }}{% endif %}</title>
    <style>
        .lm-blog { max-width: 1100px; margin: 0 auto; padding: 2rem 1rem; font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; }
        .lm-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
        .lm-card { display: flex; flex-direction: column; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; background: #fff; text-decoration: none; color: inherit; transition: box-shadow .15s ease; }
        .lm-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,.08); }
        .lm-card img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
        .lm-card-body { padding: 1rem 1.1rem 1.3rem; }
        .lm-card-title { font-size: 1.1rem; line-height: 1.3; margin: 0 0 .5rem; }
        .lm-card-excerpt { font-size: .92rem; color: #4b5563; margin: 0; }
        .lm-meta { font-size: .8rem; color: #9ca3af; margin: 0 0 .4rem; }
        .lm-empty { color: #6b7280; padding: 3rem 0; text-align: center; }
        .lm-pagination { display: flex; justify-content: space-between; margin-top: 2.5rem; }
        .lm-pagination a { text-decoration: none; font-weight: 600; }
    </style>
</head>
<body>
<main class="lm-blog">
    <h1>{{ 'Blog'|t('launchmind-blog') }}</h1>

    {% if posts is empty %}
        <p class="lm-empty">{{ 'No articles yet.'|t('launchmind-blog') }}</p>
    {% else %}
        <div class="lm-grid">
            {% for post in posts %}
                <a class="lm-card" href="{{ url(blogPath ~ '/' ~ post.slug) }}">
                    {% if post.coverImage %}
                        <img src="{{ post.coverImage }}" alt="{{ post.title }}" loading="lazy">
                    {% endif %}
                    <div class="lm-card-body">
                        {% if post.publishedAt %}
                            <p class="lm-meta">{{ post.publishedAt|date('j M Y') }}</p>
                        {% endif %}
                        <h2 class="lm-card-title">{{ post.title }}</h2>
                        {% if post.excerpt %}
                            <p class="lm-card-excerpt">{{ post.excerpt|striptags|slice(0, 160) }}</p>
                        {% endif %}
                    </div>
                </a>
            {% endfor %}
        </div>

        <nav class="lm-pagination">
            <span>{% if page > 1 %}<a href="{{ url(blogPath, { page: page - 1 }) }}">&larr; {{ 'Newer'|t('launchmind-blog') }}</a>{% endif %}</span>
            <span>{% if hasNextPage %}<a href="{{ url(blogPath, { page: page + 1 }) }}">{{ 'Older'|t('launchmind-blog') }} &rarr;</a>{% endif %}</span>
        </nav>
    {% endif %}
</main>
</body>
</html>
