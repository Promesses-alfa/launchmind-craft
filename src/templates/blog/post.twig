{#
  Launchmind blog — single article, with SEO meta, Open Graph, hreflang and
  BlogPosting JSON-LD. Copy to templates/launchmind-blog/blog/post.twig in your
  project to restyle.

  If you use SEOmatic (or another SEO plugin) and prefer it to own the meta
  tags, remove the <head> meta/JSON-LD block below and render the article body
  inside your own layout instead.

  Available: post (array), blogPath (string), canonical (string)
#}
<!DOCTYPE html>
<html lang="{{ post.language ?: craft.app.language }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ post.seo.title ?: post.title }}</title>
    {% if post.seo.description %}<meta name="description" content="{{ post.seo.description }}">{% endif %}
    <link rel="canonical" href="{{ canonical }}">

    {# Language alternates so search engines see the other translations. #}
    {% for lang in post.availableLanguages %}
        {% if lang != post.language %}
            <link rel="alternate" hreflang="{{ lang }}" href="{{ url(blogPath ~ '/' ~ post.slug, { lang: lang }) }}">
        {% endif %}
    {% endfor %}

    {# Open Graph #}
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{ post.seo.title ?: post.title }}">
    {% if post.seo.description %}<meta property="og:description" content="{{ post.seo.description }}">{% endif %}
    {% if post.coverImage %}<meta property="og:image" content="{{ post.coverImage }}">{% endif %}
    <meta property="og:url" content="{{ canonical }}">

    {# BlogPosting structured data #}
    <script type="application/ld+json">
    {{ {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: post.title,
        description: post.seo.description,
        image: post.coverImage ?: null,
        datePublished: post.publishedAt,
        author: { '@type': 'Organization', name: post.author },
        mainEntityOfPage: { '@type': 'WebPage', '@id': canonical }
    }|json_encode|raw }}
    </script>

    <style>
        .lm-article { max-width: 760px; margin: 0 auto; padding: 2.5rem 1rem 4rem; font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; color: #1f2937; line-height: 1.7; }
        .lm-article h1 { font-size: 2.1rem; line-height: 1.2; margin: 0 0 .75rem; }
        .lm-article .lm-meta { color: #9ca3af; font-size: .9rem; margin-bottom: 1.5rem; }
        .lm-article .lm-hero { width: 100%; border-radius: 14px; margin: 0 0 2rem; aspect-ratio: 16/9; object-fit: cover; }
        .lm-article :is(h2,h3) { line-height: 1.3; margin-top: 2rem; }
        .lm-article img { max-width: 100%; height: auto; border-radius: 10px; }
        .lm-article a { color: #2563eb; }
        .lm-tags { margin-top: 2.5rem; display: flex; flex-wrap: wrap; gap: .5rem; }
        .lm-tag { font-size: .8rem; background: #f3f4f6; color: #374151; border-radius: 999px; padding: .25rem .7rem; }
        .lm-back { display: inline-block; margin-bottom: 1.5rem; text-decoration: none; color: #6b7280; }
    </style>
</head>
<body>
<article class="lm-article">
    <a class="lm-back" href="{{ url(blogPath) }}">&larr; {{ 'All articles'|t('launchmind-blog') }}</a>

    <h1>{{ post.title }}</h1>
    <p class="lm-meta">
        {% if post.publishedAt %}{{ post.publishedAt|date('j M Y') }}{% endif %}
        {% if post.author %} · {{ post.author }}{% endif %}
    </p>

    {% if post.coverImage %}
        <img class="lm-hero" src="{{ post.coverImage }}" alt="{{ post.title }}">
    {% endif %}

    <div class="lm-content">
        {{ post.html|raw }}
    </div>

    {% if post.tags is not empty %}
        <div class="lm-tags">
            {% for tag in post.tags %}<span class="lm-tag">{{ tag }}</span>{% endfor %}
        </div>
    {% endif %}
</article>
</body>
</html>
